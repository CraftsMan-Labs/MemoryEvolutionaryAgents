POSTGRES_DB=memory_agents
POSTGRES_USER=memory_agents
POSTGRES_PASSWORD=memory_agents
POSTGRES_PORT=5432

QDRANT_PORT=6333

API_PORT=8000
DASHBOARD_PORT=5173

MEA_DB_PATH=/data/memory_agents.db
MEA_DATABASE_URL=postgresql://memory_agents:memory_agents@postgres:5432/memory_agents
MEA_SCAN_INTERVAL_SECONDS=300
MEA_SCAN_CYCLE_TIMEOUT_SECONDS=240
MEA_MASTER_KEY=replace_with_fernet_key

MEA_PHASE2_ENABLED=true
MEA_PHASE2_WORKFLOW_PATH=/app/workflows/ingest_memory_v1.yaml
MEA_PHASE3_ENABLED=true
MEA_PHASE3_WORKFLOW_PATH=/app/workflows/ontology_evolution_v1.yaml
MEA_PHASE3_MATCH_THRESHOLD=0.82
MEA_PHASE4_ENABLED=true
MEA_WORKFLOW_PROVIDER=openai
MEA_WORKFLOW_API_BASE=https://api.openai.com/v1
MEA_WORKFLOW_API_KEY=replace_with_provider_api_key
MEA_WORKFLOW_MODEL=gpt-4o-mini

MEA_QDRANT_URL=http://qdrant:6333
MEA_QDRANT_API_KEY=
MEA_QDRANT_COLLECTION=memory_chunks
MEA_OBSIDIAN_VAULT_PATH=/data/obsidian-vault
